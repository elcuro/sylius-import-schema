<?xml version="1.0" encoding="UTF-8"?>
<!--
    Example for EXTERNAL SUPPLIERS
    ══════════════════════════════════════════════════════════════════
    Use this file as a template if:
      - you generate XML from your own ERP / e-commerce system / warehouse
      - you do not know our internal codes (categories, attributes, options)
      - you want to include your own codes for later mapping on our side

    All text content (names, descriptions, values, URLs) lives in child
    elements so you can safely include quotes, apostrophes, ampersands
    and HTML without escaping — just wrap them in <![CDATA[ ... ]]>.

    Validation before sending:
    ══════════════════════════════════════════════════════════════════
-->
<sylius-import version="2.0"
               default-locale="en_US"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:noNamespaceSchemaLocation="https://elcuro.github.io/sylius-import-schema/sylius-import-2.0.xsd">

    <products>

        <!-- ═══════════════════════════════════════
             EXAMPLE 1: Product with variants (color + storage)
             Supplier does not know our codes — uses their own.
             ═══════════════════════════════════════ -->
        <product enabled="true">
            <external-code>BB-987654</external-code>
            <!-- manufacturer = who physically makes the device;
                 brand         = marketing label the consumer recognises. -->
            <manufacturer>Foxconn Technology Group</manufacturer>
            <brand>Apple</brand>

            <!-- At least one translation is required.
                 If locale is omitted, default-locale from root element is used (en_US). -->
            <translations>
                <translation>
                    <name>Apple iPhone 15 Pro</name>
                    <short-description>The most powerful iPhone ever — with "ProMotion" display.</short-description>
                    <description><![CDATA[<p>iPhone 15 Pro with A17 Pro chip and titanium frame.</p>
<ul><li>6.1" Super Retina XDR</li><li>A17 Pro & 8 GB RAM</li></ul>]]></description>
                    <meta-title>Apple iPhone 15 Pro | Buy online</meta-title>
                    <meta-description>Buy Apple iPhone 15 Pro at the best price.</meta-description>
                </translation>
                <translation locale="de_DE">
                    <name>Apple iPhone 15 Pro</name>
                    <short-description>Das leistungsstärkste iPhone aller Zeiten.</short-description>
                    <description><![CDATA[<p>iPhone 15 Pro mit A17 Pro Chip und Titanrahmen.</p>]]></description>
                </translation>
                <translation locale="fr_FR">
                    <name>Apple iPhone 15 Pro</name>
                    <short-description>L'iPhone le plus puissant jamais conçu.</short-description>
                </translation>
            </translations>

            <!-- Categories — name is the human-readable name from your system.
                 Our importer will map them to our internal categories. -->
            <taxons>
                <taxon>
                    <external-code>CAT-SMART</external-code>
                    <name>Smartphones</name>
                </taxon>
                <taxon>
                    <external-code>CAT-APPLE</external-code>
                    <name>Apple</name>
                </taxon>
                <taxon>
                    <external-code>CAT-MOB</external-code>
                    <name>Mobile phones &amp; accessories</name>
                </taxon>
            </taxons>

            <!-- Attributes — name + value are human-readable text.
                 external-code / external-value-code are your internal codes. -->
            <attributes>
                <attribute>
                    <name>Brand</name>
                    <external-code>ATTR-BRD</external-code>
                    <value>Apple</value>
                    <external-value-code>BRD-001</external-value-code>
                </attribute>
                <attribute>
                    <name>Screen size</name>
                    <external-code>ATTR-SCR</external-code>
                    <value>6.1"</value>
                </attribute>
                <attribute>
                    <name>OS</name>
                    <external-code>ATTR-OS</external-code>
                    <value>iOS 17</value>
                    <external-value-code>OS-IOS17</external-value-code>
                </attribute>
                <attribute>
                    <name>Material</name>
                    <external-code>ATTR-MAT</external-code>
                    <value>Titanium</value>
                    <external-value-code>MAT-TIT</external-value-code>
                </attribute>
            </attributes>

            <!-- Images — url is the absolute URL to the image.
                 The first image with type="main" will be used as the primary image.
                 URLs with query strings (&) are fine in element content. -->
            <images>
                <image type="main">
                    <url>https://cdn.supplier.eu/iphone15pro/front.jpg?v=2&amp;size=800</url>
                </image>
                <image type="additional">
                    <url>https://cdn.supplier.eu/iphone15pro/side.jpg</url>
                </image>
                <image type="additional">
                    <url>https://cdn.supplier.eu/iphone15pro/back.jpg</url>
                </image>
                <image type="thumbnail">
                    <url>https://cdn.supplier.eu/iphone15pro/thumb.jpg</url>
                </image>
            </images>

            <variants>

                <!-- Variant: Black / 128 GB -->
                <variant enabled="true" condition="new">
                    <external-code>BB-987654-BLK-128</external-code>
                    <ean>5901234100128</ean>
                    <translation>
                        <name>Black / 128 GB</name>
                    </translation>
                    <translation locale="de_DE">
                        <name>Schwarz / 128 GB</name>
                    </translation>

                    <!-- Options — name + value are human-readable text from your system.
                         external-code / external-value-code are your internal codes. -->
                    <options>
                        <option>
                            <name>Color</name>
                            <external-code>OPT-COL</external-code>
                            <value>Black</value>
                            <external-value-code>COL-BLK</external-value-code>
                        </option>
                        <option>
                            <name>Storage</name>
                            <external-code>OPT-MEM</external-code>
                            <value>128 GB</value>
                            <external-value-code>MEM-128</external-value-code>
                        </option>
                    </options>

                    <!-- Price in cents (with VAT): 143880 = 1,438.80 EUR incl. 20 % VAT
                         Supplier quotes gross prices → use vat-amount + vat.
                         The importer derives the net amount from vat-amount / (1 + vat/100). -->
                    <price currency="EUR" vat-amount="143880" vat="20" />

                    <!-- Stock on hand -->
                    <stock on-hand="50" />

                    <!-- Dimensions: weight in kg, all other values in mm -->
                    <dimensions weight="0.187" width="71.5" height="146.6" depth="8.25" />
                </variant>

                <!-- Variant: Black / 256 GB -->
                <variant enabled="true" condition="refurbished">
                    <external-code>BB-987654-BLK-256</external-code>
                    <ean>5901234100256</ean>
                    <translation>
                        <name>Black / 256 GB</name>
                    </translation>
                    <translation locale="de_DE">
                        <name>Schwarz / 256 GB</name>
                    </translation>
                    <options>
                        <option>
                            <name>Color</name>
                            <external-code>OPT-COL</external-code>
                            <value>Black</value>
                            <external-value-code>COL-BLK</external-value-code>
                        </option>
                        <option>
                            <name>Storage</name>
                            <external-code>OPT-MEM</external-code>
                            <value>256 GB</value>
                            <external-value-code>MEM-256</external-value-code>
                        </option>
                    </options>
                    <price currency="EUR" vat-amount="161880" vat="20" />
                    <stock on-hand="30" />
                    <dimensions weight="0.187" width="71.5" height="146.6" depth="8.25" />
                </variant>

                <!-- Variant: White / 128 GB -->
                <variant enabled="true" condition="used">
                    <external-code>BB-987654-WHT-128</external-code>
                    <ean>5901234200128</ean>
                    <translation>
                        <name>White / 128 GB</name>
                    </translation>
                    <translation locale="de_DE">
                        <name>Weiß / 128 GB</name>
                    </translation>
                    <options>
                        <option>
                            <name>Color</name>
                            <external-code>OPT-COL</external-code>
                            <value>White</value>
                            <external-value-code>COL-WHT</external-value-code>
                        </option>
                        <option>
                            <name>Storage</name>
                            <external-code>OPT-MEM</external-code>
                            <value>128 GB</value>
                            <external-value-code>MEM-128</external-value-code>
                        </option>
                    </options>
                    <!-- Alternative: supplier is a VAT payer and reports net prices → use amount only -->
                    <price currency="EUR" amount="119900" />
                    <stock on-hand="25" />
                    <dimensions weight="0.187" width="71.5" height="146.6" depth="8.25" />
                </variant>

            </variants>

            <!-- GPSR (EU 2023/988) — manufacturer is outside the EU (US),
                 so an EU responsible person (Art. 16) must be named.
                 Safety notices are translated into the consumer's language
                 (Art. 9(7-8), Art. 19(4)(d)). External safety documents
                 link to PDFs such as the user manual and DoC. -->
            <gpsr>
                <manufacturer>
                    <name>Apple Inc.</name>
                    <trademark>Apple</trademark>
                    <street>One Apple Park Way</street>
                    <city>Cupertino</city>
                    <postal-code>95014</postal-code>
                    <country>US</country>
                    <email>productsafety@apple.com</email>
                    <phone>+1-408-996-1010</phone>
                </manufacturer>
                <eu-responsible-person>
                    <name>Apple Distribution International Ltd.</name>
                    <street>Hollyhill Industrial Estate, Hollyhill</street>
                    <city>Cork</city>
                    <postal-code>T23 YK84</postal-code>
                    <country>IE</country>
                    <email>eu-productsafety@apple.com</email>
                </eu-responsible-person>
                <model>A3102</model>
                <safety-notices>
                    <notice><![CDATA[<p>Charge only with original adapter.
Do not use a damaged cable. Keep away from liquids & small children.</p>]]></notice>
                    <notice locale="de_DE"><![CDATA[<p>Nur mit originalem Netzteil laden.
Beschädigte Kabel nicht verwenden.</p>]]></notice>
                </safety-notices>
                <!-- URLs point to real, publicly downloadable sample PDFs
                     from sample-files.com so the example can be copy-pasted
                     into an importer smoke test without needing live
                     manufacturer URLs. -->
                <safety-documents>
                    <document type="user-manual" locale="en_US">
                        <url>https://sample-files.com/downloads/documents/pdf/sample-20-page-pdf-a4-size.pdf</url>
                    </document>
                    <document type="user-manual" locale="de_DE">
                        <url>https://sample-files.com/downloads/documents/pdf/sample-10-page-pdf-a4-size.pdf</url>
                    </document>
                    <document type="declaration-of-conformity">
                        <url>https://sample-files.com/downloads/documents/pdf/sample-pdf-a4-size.pdf</url>
                    </document>
                </safety-documents>
                <certifications>
                    <certification>
                        <code>CE</code>
                    </certification>
                    <certification>
                        <code>RoHS</code>
                    </certification>
                </certifications>
            </gpsr>
        </product>

        <!-- ═══════════════════════════════════════
             EXAMPLE 2: Simple product (single variant, no options)
             Demonstrates ampersands, apostrophes and unescaped HTML via CDATA.
             ═══════════════════════════════════════ -->
        <product enabled="true">
            <external-code>CABLE-001</external-code>
            <manufacturer>Ben &amp; Jerry's Electronics</manufacturer>
            <brand>Ben &amp; Jerry's</brand>

            <translations>
                <translation>
                    <name>USB-C Cable 1m "Fast Charge"</name>
                    <description><![CDATA[<p>Fast-charging USB-C cable, 1 meter length.</p><p>Works with iPhone & Android.</p>]]></description>
                </translation>
                <translation locale="de_DE">
                    <name>USB-C Kabel 1m</name>
                </translation>
            </translations>

            <taxons>
                <taxon>
                    <external-code>CAT-CABLE</external-code>
                    <name>Cables &amp; Adapters</name>
                </taxon>
            </taxons>

            <attributes>
                <attribute>
                    <name>Brand</name>
                    <value>Ben &amp; Jerry's</value>
                    <external-value-code>BRD-BJ</external-value-code>
                </attribute>
                <attribute>
                    <name>Length</name>
                    <value>1m</value>
                </attribute>
            </attributes>

            <images>
                <image type="main">
                    <url>https://cdn.supplier.eu/cables/usb-c-1m.jpg</url>
                </image>
            </images>

            <variants>
                <!-- Single variant with no options -->
                <variant enabled="true" condition="new">
                    <external-code>CABLE-001-DEFAULT</external-code>
                    <ean>5901234000015</ean>
                    <translation>
                        <name>USB-C Cable 1m</name>
                    </translation>
                    <price currency="EUR" vat-amount="1788" vat="20" />
                    <stock on-hand="200" />
                    <dimensions weight="0.05" width="15" height="150" depth="10" />
                </variant>
            </variants>

            <!-- GPSR with an EU-established manufacturer — no
                 eu-responsible-person needed (Art. 16 does not apply). -->
            <gpsr>
                <manufacturer>
                    <name>Ben &amp; Jerry's Electronics GmbH</name>
                    <street>Industriestraße 7</street>
                    <city>Berlin</city>
                    <postal-code>10115</postal-code>
                    <country>DE</country>
                    <email>safety@bj-electronics.example</email>
                </manufacturer>
                <safety-notices>
                    <notice><![CDATA[Do not submerge in water. Keep away from fire.]]></notice>
                </safety-notices>
            </gpsr>
        </product>

    </products>

</sylius-import>
