<?xml version="1.0" encoding="UTF-8"?>
<!--
    Example for EXTERNAL SUPPLIERS
    ══════════════════════════════════════════════════════════════════
    Use this file as a template if:
      - you generate XML from your own ERP / e-commerce system / warehouse
      - you do not know our internal codes (categories, attributes, options)
      - you want to include your own codes for later mapping on our side

    Validation before sending:
    ══════════════════════════════════════════════════════════════════
-->
<sylius-import version="2.0"
               default-locale="en_US"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:noNamespaceSchemaLocation="https://elcuro.github.io/sylius-import-schema/sylius-import-2.0.xsd">

    <products>

        <!-- ═══════════════════════════════════════
             EXAMPLE 1: Product with variants (color + storage)
             Supplier does not know our codes — uses their own.
             ═══════════════════════════════════════ -->
        <product external-code="BB-987654" enabled="true">

            <!-- At least one translation is required.
                 If locale is omitted, default-locale from root element is used (en_US). -->
            <translations>
                <translation name="Apple iPhone 15 Pro"
                             short-description="The most powerful iPhone ever."
                             description="&lt;p&gt;iPhone 15 Pro with A17 Pro chip and titanium frame.&lt;/p&gt;"
                             meta-title="Apple iPhone 15 Pro | Buy online"
                             meta-description="Buy Apple iPhone 15 Pro at the best price." />
                <translation locale="de_DE"
                             name="Apple iPhone 15 Pro"
                             short-description="Das leistungsstärkste iPhone aller Zeiten."
                             description="&lt;p&gt;iPhone 15 Pro mit A17 Pro Chip und Titanrahmen.&lt;/p&gt;" />
                <translation locale="fr_FR"
                             name="Apple iPhone 15 Pro"
                             short-description="L'iPhone le plus puissant jamais conçu." />
            </translations>

            <!-- Categories — name is the human-readable name from your system.
                 Our importer will map them to our internal categories. -->
            <taxons>
                <taxon name="Smartphones"    external-code="CAT-SMART" />
                <taxon name="Apple"          external-code="CAT-APPLE" />
                <taxon name="Mobile phones"  external-code="CAT-MOB" />
            </taxons>

            <!-- Attributes — name + value are human-readable text.
                 external-code / external-value-code are your internal codes. -->
            <attributes>
                <attribute name="Brand"        external-code="ATTR-BRD"
                           value="Apple"       external-value-code="BRD-001" />
                <attribute name="Screen size"  external-code="ATTR-SCR"
                           value="6.1" />
                <attribute name="OS"           external-code="ATTR-OS"
                           value="iOS 17"      external-value-code="OS-IOS17" />
                <attribute name="Material"     external-code="ATTR-MAT"
                           value="Titanium"    external-value-code="MAT-TIT" />
            </attributes>

            <!-- Images — url must be an absolute URL to the image.
                 The first image with type="main" will be used as the primary image. -->
            <images>
                <image url="https://cdn.supplier.eu/iphone15pro/front.jpg"  type="main" />
                <image url="https://cdn.supplier.eu/iphone15pro/side.jpg"   type="additional" />
                <image url="https://cdn.supplier.eu/iphone15pro/back.jpg"   type="additional" />
                <image url="https://cdn.supplier.eu/iphone15pro/thumb.jpg"  type="thumbnail" />
            </images>

            <variants>

                <!-- Variant: Black / 128 GB -->
                <variant external-code="BB-987654-BLK-128" enabled="true">
                    <translation name="Black / 128 GB" />
                    <translation locale="de_DE" name="Schwarz / 128 GB" />

                    <!-- Options — name + value are human-readable text from your system.
                         external-code / external-value-code are your internal codes. -->
                    <options>
                        <option name="Color"    external-code="OPT-COL"
                                value="Black"   external-value-code="COL-BLK" />
                        <option name="Storage"  external-code="OPT-MEM"
                                value="128 GB"  external-value-code="MEM-128" />
                    </options>

                    <!-- Price in cents: 119900 = 1,199.00 EUR -->
                    <price currency="EUR" amount="119900" />

                    <!-- Stock on hand -->
                    <stock on-hand="50" />

                    <!-- Dimensions: weight in kg, all other values in mm -->
                    <dimensions weight="0.187" width="71.5" height="146.6" depth="8.25" />
                </variant>

                <!-- Variant: Black / 256 GB -->
                <variant external-code="BB-987654-BLK-256" enabled="true">
                    <translation name="Black / 256 GB" />
                    <translation locale="de_DE" name="Schwarz / 256 GB" />
                    <options>
                        <option name="Color"    external-code="OPT-COL"
                                value="Black"   external-value-code="COL-BLK" />
                        <option name="Storage"  external-code="OPT-MEM"
                                value="256 GB"  external-value-code="MEM-256" />
                    </options>
                    <price currency="EUR" amount="134900" />
                    <stock on-hand="30" />
                    <dimensions weight="0.187" width="71.5" height="146.6" depth="8.25" />
                </variant>

                <!-- Variant: White / 128 GB -->
                <variant external-code="BB-987654-WHT-128" enabled="true">
                    <translation name="White / 128 GB" />
                    <translation locale="de_DE" name="Weiß / 128 GB" />
                    <options>
                        <option name="Color"    external-code="OPT-COL"
                                value="White"   external-value-code="COL-WHT" />
                        <option name="Storage"  external-code="OPT-MEM"
                                value="128 GB"  external-value-code="MEM-128" />
                    </options>
                    <price currency="EUR" amount="119900" />
                    <stock on-hand="25" />
                    <dimensions weight="0.187" width="71.5" height="146.6" depth="8.25" />
                </variant>

            </variants>
        </product>

        <!-- ═══════════════════════════════════════
             EXAMPLE 2: Simple product (single variant, no options)
             ═══════════════════════════════════════ -->
        <product external-code="CABLE-001" enabled="true">

            <translations>
                <translation name="USB-C Cable 1m"
                             description="&lt;p&gt;Fast-charging USB-C cable, 1 meter length.&lt;/p&gt;" />
                <translation locale="de_DE" name="USB-C Kabel 1m" />
            </translations>

            <taxons>
                <taxon name="Cables &amp; Adapters" external-code="CAT-CABLE" />
            </taxons>

            <attributes>
                <attribute name="Brand"  value="Baseus" external-value-code="BRD-BAS" />
                <attribute name="Length" value="1m" />
            </attributes>

            <images>
                <image url="https://cdn.supplier.eu/cables/usb-c-1m.jpg" type="main" />
            </images>

            <variants>
                <!-- Single variant with no options -->
                <variant external-code="CABLE-001-DEFAULT" enabled="true">
                    <translation name="USB-C Cable 1m" />
                    <price currency="EUR" amount="1490" />
                    <stock on-hand="200" />
                    <dimensions weight="0.05" width="15" height="150" depth="10" />
                </variant>
            </variants>

        </product>

    </products>

</sylius-import>
