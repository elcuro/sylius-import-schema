<?xml version="1.0" encoding="UTF-8"?>
<!--
    Example MANIFEST file for multi-file imports
    ══════════════════════════════════════════════════════════════════
    Use this file when your export is split across multiple XML files.
    The importer processes each file in the order listed here.
    Each referenced file must be a valid sylius-import document.

    Single-file export:  send one sylius-import XML file directly.
    Multi-file export:   send this manifest alongside the product files.

    Each <file> element contains either a relative path (resolved against
    the manifest's own location) or an absolute http(s) URL. Both forms
    may be mixed within the same manifest.
    ══════════════════════════════════════════════════════════════════
-->
<sylius-import-manifest version="2.0"
                        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                        xsi:noNamespaceSchemaLocation="https://elcuro.github.io/sylius-import-schema/sylius-import-2.0.xsd">

    <files>
        <!-- Relative path — resolved next to this manifest file -->
        <file>products-001.xml</file>
        <file>products-002.xml</file>
        <!-- Absolute URL — fetched directly over HTTP(S) -->
        <file>https://cdn.example.com/exports/2026-04/products-003.xml</file>
    </files>

</sylius-import-manifest>
