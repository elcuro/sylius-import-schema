<?xml version="1.0" encoding="UTF-8"?>
<!--
    Example for SYLIUS TO SYLIUS TRANSFER
    ══════════════════════════════════════════════════════════════════
    Use this file as a template if:
      - you are exporting products from one Sylius instance to another
      - you know the target internal codes (categories, attributes, options)
      - you want to preserve slugs, Sylius codes and the full data structure

    Validation before sending:
    ══════════════════════════════════════════════════════════════════
-->
<sylius-import version="2.0"
               default-locale="en_US"
               channel="default"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:noNamespaceSchemaLocation="https://elcuro.github.io/sylius-import-schema/sylius-import-2.0.xsd">

    <products>

        <!-- ═══════════════════════════════════════
             EXAMPLE 1: Product with variants
             Sylius to Sylius: all codes are our internal Sylius codes.
             ═══════════════════════════════════════ -->
        <product code="IPHONE-15-PRO" enabled="true" manufacturer="Apple">

            <translations>
                <!-- slug is preserved from the source Sylius instance -->
                <translation locale="en_US"
                             name="Apple iPhone 15 Pro"
                             slug="apple-iphone-15-pro-en"
                             short-description="The most powerful iPhone ever."
                             description="&lt;p&gt;iPhone 15 Pro with A17 Pro chip and titanium frame.&lt;/p&gt;"
                             meta-title="Apple iPhone 15 Pro | Buy online"
                             meta-description="Buy Apple iPhone 15 Pro at the best price." />
                <translation locale="de_DE"
                             name="Apple iPhone 15 Pro"
                             slug="apple-iphone-15-pro-de"
                             short-description="Das leistungsstärkste iPhone aller Zeiten."
                             description="&lt;p&gt;iPhone 15 Pro mit A17 Pro Chip und Titanrahmen.&lt;/p&gt;"
                             meta-title="Apple iPhone 15 Pro | Online kaufen" />
                <translation locale="fr_FR"
                             name="Apple iPhone 15 Pro"
                             slug="apple-iphone-15-pro-fr"
                             short-description="L'iPhone le plus puissant jamais conçu." />
            </translations>

            <!-- Taxons — code is our Sylius code.
                 main = code of the main taxon. -->
            <taxons main="electronics-phones">
                <taxon code="electronics-phones" />
                <taxon code="electronics" />
                <taxon code="apple-products" />
            </taxons>

            <!-- Attributes — code is the Sylius attribute code.
                 Use value-code for select types, value for text / float / integer. -->
            <attributes>
                <attribute code="brand"       value-code="apple" />
                <attribute code="screen_size" value="6.1" />
                <attribute code="os"          value-code="ios_17" />
                <attribute code="material"    value-code="titanium" />
            </attributes>

            <!-- Images — path is the relative path in the Sylius media directory.
                 You may also use url if images are publicly accessible online. -->
            <images>
                <image path="iphone-15-pro/front.jpg"  type="main" />
                <image path="iphone-15-pro/side.jpg"   type="additional" />
                <image path="iphone-15-pro/back.jpg"   type="additional" />
                <image path="iphone-15-pro/thumb.jpg"  type="thumbnail" />
            </images>

            <variants>

                <!-- Variant: Black / 128 GB -->
                <variant code="IPHONE-15-PRO-BLK-128" enabled="true" ean="5901234100128" condition="new">
                    <translation locale="en_US" name="Black / 128 GB"
                                 slug="apple-iphone-15-pro-black-128gb" />
                    <translation locale="de_DE" name="Schwarz / 128 GB"
                                 slug="apple-iphone-15-pro-schwarz-128gb" />

                    <!-- Options — code is the Sylius option code, value-code is the Sylius value code -->
                    <options>
                        <option code="color"   value-code="color_black" />
                        <option code="storage" value-code="storage_128" />
                    </options>

                    <!-- Sylius-to-Sylius: net amount is known; vat carries the rate for re-use -->
                    <price currency="EUR" amount="119900" vat="20" />
                    <stock on-hand="50" />
                    <dimensions weight="0.187" width="71.5" height="146.6" depth="8.25" />
                </variant>

                <!-- Variant: Black / 256 GB -->
                <variant code="IPHONE-15-PRO-BLK-256" enabled="true" ean="5901234100256" condition="refurbished">
                    <translation locale="en_US" name="Black / 256 GB"
                                 slug="apple-iphone-15-pro-black-256gb" />
                    <translation locale="de_DE" name="Schwarz / 256 GB"
                                 slug="apple-iphone-15-pro-schwarz-256gb" />
                    <options>
                        <option code="color"   value-code="color_black" />
                        <option code="storage" value-code="storage_256" />
                    </options>
                    <!-- Both net and gross supplied — importer reconciles against vat -->
                    <price currency="EUR" amount="134900" vat-amount="161880" vat="20" />
                    <stock on-hand="30" />
                    <dimensions weight="0.187" width="71.5" height="146.6" depth="8.25" />
                </variant>

                <!-- Variant: White / 128 GB -->
                <variant code="IPHONE-15-PRO-WHT-128" enabled="true" condition="used">
                    <translation locale="en_US" name="White / 128 GB"
                                 slug="apple-iphone-15-pro-white-128gb" />
                    <translation locale="de_DE" name="Weiß / 128 GB"
                                 slug="apple-iphone-15-pro-weiss-128gb" />
                    <options>
                        <option code="color"   value-code="color_white" />
                        <option code="storage" value-code="storage_128" />
                    </options>
                    <price currency="EUR" amount="119900" vat="20" />
                    <stock on-hand="25" />
                    <dimensions weight="0.187" width="71.5" height="146.6" depth="8.25" />
                </variant>

            </variants>
        </product>

        <!-- ═══════════════════════════════════════
             EXAMPLE 2: Product known to both sides
             Sylius codes + preserved supplier external codes.
             Useful when migrating from a supplier-fed catalog.
             ═══════════════════════════════════════ -->
        <product code="CABLE-USB-C-1M" external-code="BB-CABLE-001" enabled="true" manufacturer="Baseus">

            <translations>
                <translation locale="en_US"
                             name="USB-C Cable 1m"
                             slug="usb-c-cable-1m"
                             description="&lt;p&gt;Fast-charging USB-C cable, 1 meter length.&lt;/p&gt;" />
                <translation locale="de_DE"
                             name="USB-C Kabel 1m"
                             slug="usb-c-kabel-1m" />
            </translations>

            <taxons main="cables">
                <taxon code="cables" />
                <taxon code="accessories" />
            </taxons>

            <attributes>
                <attribute code="brand"  value-code="baseus" />
                <attribute code="length" value="1" />
            </attributes>

            <images>
                <image path="cables/usb-c-1m.jpg" type="main" />
            </images>

            <variants>
                <variant code="CABLE-USB-C-1M-DEFAULT" external-code="BB-CABLE-001-DEF" enabled="true" condition="new">
                    <translation locale="en_US" name="USB-C Cable 1m"
                                 slug="usb-c-cable-1m-default" />
                    <price currency="EUR" amount="1490" vat="20" />
                    <stock on-hand="200" />
                    <dimensions weight="0.05" width="15" height="150" depth="10" />
                </variant>
            </variants>

        </product>

    </products>

</sylius-import>
